<mujoco model="mecanumbot">

  <compiler angle="radian" meshdir="meshes/"/>

  <option cone="elliptic" impratio="10"/>

  <!-- Assets -->
  <asset>
    <material name="dark" rgba="0.3 0.3 0.3 1"/>
    <material name="light_blue" rgba="0.1 0.1 0.5 1"/>
    <material name="green" rgba="0.0 0.8 0.0 1"/>
    <material name="orange" rgba="1.0 0.4235 0.0392 1"/>
    <material name="red" rgba="0.8 0.0 0.0 1"/>

    <mesh name="base" file="base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="wheel" file="wheel.stl" scale="0.001 0.001 0.001"/>
    <mesh name="arm_left" file="arm_left.stl" scale="0.001 0.001 0.001"/>
    <mesh name="arm_right" file="arm_right.stl" scale="0.001 0.001 0.001"/>
    <mesh name="head" file="head.stl" scale="0.001 0.001 0.001"/>
    <mesh name="lds" file="lds.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <!-- Defaults -->
  <default>
    <default class="wheel">
      <joint axis="0 0 1" limited="false" damping="0.1"/>
      <geom type="cylinder" size="0.033 0.015"
            friction="1 0.05 0.05" /> <!-- mecanum approximation -->
      <velocity ctrlrange="-10 10"/>
    </default>
  </default>

  <!-- World -->
  <worldbody>
    <body name="base" pos="0 0 0">
      
      <!-- Free base -->
      <joint type="free"/>

      <!-- Base -->
      <geom mesh="base" material="dark"/>
      <geom type="box" size="0.0225 0.13 0.045" pos="0.085 0 0.135"/>
      
      <!-- Wheels -->
      <body name="wheel_fl" pos="0.064 0.1522 0.02345" quat="0.707 0.707 0 0">
        <joint name="wheel_fl_joint" class="wheel"/>
        <geom mesh="wheel" material="light_blue"/>
      </body>

      <body name="wheel_bl" pos="-0.064 0.1522 0.02345" quat="0.707 0.707 0 0">
        <joint name="wheel_bl_joint" class="wheel"/>
        <geom mesh="wheel" material="light_blue"/>
      </body>

      <body name="wheel_fr" pos="0.064 -0.1522 0.02345" quat="0.707 -0.707 0 0">
        <joint name="wheel_fr_joint" class="wheel"/>
        <geom mesh="wheel" material="light_blue"/>
      </body>

      <body name="wheel_br" pos="-0.064 -0.1522 0.02345" quat="0.707 -0.707 0 0">
        <joint name="wheel_br_joint" class="wheel"/>
        <geom mesh="wheel" material="light_blue"/>
      </body>

      <!-- Grabbers -->
      <body name="grabber_right" pos="0.174 -0.070 0.024">
        <joint name="grabber_right_joint" range="-1.57 1.57"/>
        <geom mesh="arm_right" material="green"/>
      </body>

      <body name="grabber_left" pos="0.174 0.070 0.024">
        <joint name="grabber_left_joint" range="-1.57 1.57"/>
        <geom mesh="arm_left" material="green"/>
      </body>

      <!-- Head -->
      <body name="head" pos="0.1063 0 0.1679" quat="0.707 0.707 0 0">
        <joint name="head_joint" range="-1.57 1.57"/>
        <geom mesh="head" material="orange"/>

        <!-- Camera -->
        <body name="camera" pos="0.022 0.038 0">
          <geom type="box" size="0.0075 0.015 0.0135" material="red"/>
        </body>
      </body>

      <!-- Lidar -->
      <body name="lidar" pos="0 0 0.122">
        <geom mesh="lds" material="dark"/>
        <geom type="cylinder" size="0.055 0.015"/>
      </body>

    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>
    <!-- Mecanum wheels -->
    <velocity name="fl" joint="wheel_fl_joint"/>
    <velocity name="fr" joint="wheel_fr_joint"/>
    <velocity name="bl" joint="wheel_bl_joint"/>
    <velocity name="br" joint="wheel_br_joint"/>

    <!-- Arm + head -->
    <position name="grabber_left" joint="grabber_left_joint"/>
    <position name="grabber_right" joint="grabber_right_joint"/>
    <position name="head" joint="head_joint"/>
  </actuator>

  <!-- Contact exclusions -->
  <contact>
    <exclude body1="base" body2="wheel_fl"/>
    <exclude body1="base" body2="wheel_fr"/>
    <exclude body1="base" body2="wheel_bl"/>
    <exclude body1="base" body2="wheel_br"/>
  </contact>

</mujoco>